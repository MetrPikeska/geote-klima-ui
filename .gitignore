# ============================================
# GEOTE Climate UI - Git Ignore Rules
# ============================================

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment Variables (SENSITIVE - DO NOT COMMIT)
.env
.env.local
.env.production
*.env

# Logs
logs/
*.log
*.log.*

# Operating System Files
.DS_Store        # macOS
Thumbs.db        # Windows
Desktop.ini      # Windows
nul

# Database Files (large/sensitive)
data.zip
database_ready/
databaze_ready/
*.db
*.sqlite

# Process IDs (created by start.sh)
*.pid

# Backups
*.bak
*.backup
README.md.bak

# IDE / Editor
.vscode/
.idea/
*.swp
*.swo
*~

# Temporary Files
tmp/
temp/
*.tmp

# Compiled / Distribution
dist/
build/

# Production config (contains live Cloudflare Tunnel URLs — generate with start-tunnels.sh)
js/config.production.js

# Database config (contains credentials)
pg-featureserv/config/pg_featureserv.toml

# Dev/debug scripts (may contain hardcoded credentials or IPs)
backend/test-*.js
backend/check-*.js
backend/describe-*.js
backend/query-*.js
backend/server-original.js
backend/server-batch.js
backend/server-with-cache.js
backend/.env.save
docker-compose.yml
